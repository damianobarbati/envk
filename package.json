{
  "name": "envk",
  "version": "4.0.0",
  "description": "Autoload your environment variables from your `.env` file, no code changes required. Similar to `dotenv`, but with zero-dependencies and less verbose.",
  "author": "Damiano Barbati <damiano.barbati@gmail.com> (https://github.com/damianobarbati)",
  "repository": "https://github.com/damianobarbati/envk",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14",
    "pnpm": ">=10.33"
  },
  "keywords": [
    "env",
    ".env",
    "dotenv",
    "environment",
    "variables",
    "environment variables"
  ],
  "type": "module",
  "main": "src/index.js",
  "exports": {
    "./": "./src/autoload.js",
    "./fn": "./src/index.js"
  },
  "scripts": {
    "postinstall": "pnpm audit --audit-level critical",
    "lint": "biome check --write",
    "test": "node --test ./src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13"
  }
}
